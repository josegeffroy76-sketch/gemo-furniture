# Copy this file to .env.local and fill in real values.
# .env.local is already git-ignored — never commit real API keys.

# ── Site ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Stripe (https://dashboard.stripe.com/apikeys) ───────────────────────────
# Use the "sk_test_..." key while developing; switch to "sk_live_..." at launch.
STRIPE_SECRET_KEY=
# From the Stripe CLI ("stripe listen") locally, or the Dashboard webhook
# config in production. Needed to record paid orders in /admin/orders.
STRIPE_WEBHOOK_SECRET=

# ── Shippo (https://apps.goshippo.com/settings/api) ─────────────────────────
# Without this, checkout still works using a transparent flat-rate estimate.
SHIPPO_API_TOKEN=

# Warehouse / ship-from address used to quote Shippo rates.
WAREHOUSE_STREET1=1063 N Glassell St
WAREHOUSE_CITY=Orange
WAREHOUSE_STATE=CA
WAREHOUSE_ZIP=92867

# ── Admin panel (/admin) ─────────────────────────────────────────────────────
ADMIN_PASSWORD=
# Any long random string — used to sign the admin session cookie.
ADMIN_SESSION_SECRET=

# ── Product photos (Vercel Blob) ─────────────────────────────────────────────
# In Vercel: Storage tab → Create Database → Blob → connect to this project.
# Vercel injects this automatically once connected — you shouldn't need to set
# it by hand. Without it, photo uploads in /admin/products show a friendly
# "not set up yet" message instead of failing.
BLOB_READ_WRITE_TOKEN=

# ── Admin data & orders (Redis/KV) ───────────────────────────────────────────
# REQUIRED for production. Vercel's application filesystem is read-only at
# runtime, so without a real store, every admin edit (price/stock, custom
# products, photos) and every order logged from the Stripe webhook will fail.
# In Vercel: Storage tab → Create Database → pick a Redis/KV provider (e.g.
# Upstash) → connect to this project. Vercel injects the URL/token pair
# automatically — the exact names vary by provider (KV_REST_API_URL /
# KV_REST_API_TOKEN, or UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN);
# src/lib/json-file-store.ts checks the common variants. Without this,
# local development falls back to local JSON files under /data (fine for
# demos, not for production).
KV_REST_API_URL=
KV_REST_API_TOKEN=
